VITE_API_BASE_URL=http://localhost:7005

# Solo para entorno local si EDGE_API_TOKEN esta activo en gateway
VITE_EDGE_API_TOKEN=

# Auth mode: dev | firebase
VITE_AUTH_MODE=dev

# Firebase client config (requerido solo si VITE_AUTH_MODE=firebase)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Usado para flujo dev en la accion de modificacion en caliente
VITE_ADMIN_DEV_UID=admin-dev-uid